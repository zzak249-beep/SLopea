# ╔══════════════════════════════════════════════════╗
# ║  APEX FUSION BOT — Variables de Entorno          ║
# ║  Copiar a .env y rellenar los valores reales     ║
# ╚══════════════════════════════════════════════════╝

# ─── BingX API ───────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui
BINGX_BASE_URL=https://open-api.bingx.com

# ─── Telegram Bot ────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ─── Configuración de Trading ────────────────────────
# Porcentaje del capital por trade (1-5 recomendado)
RISK_PER_TRADE=2
# RR mínimo para entrar
MIN_RR=2.5
# Apalancamiento (5-20 recomendado para crypto)
LEVERAGE=10
# Número máximo de trades abiertos simultáneos
MAX_OPEN_TRADES=5
# Capital máximo en USD por trade
MAX_TRADE_SIZE_USD=100

# ─── Filtros de Mercado ──────────────────────────────
# Volumen mínimo 24h en USD para operar el par
MIN_VOLUME_24H=500000
# Score mínimo LONG/SHORT para activar señal (0-100)
MIN_SCORE_ENTRY=62
# Score mínimo FUEL para señal prioritaria
MIN_SCORE_FUEL=72
# Score SUPREMA
MIN_SCORE_SUPREME=85

# ─── Timeframes ──────────────────────────────────────
TIMEFRAME_PRIMARY=3m
TIMEFRAME_HTF=15m
TIMEFRAME_TREND=1h

# ─── Modo de Operación ───────────────────────────────
# paper = simulación sin dinero real | live = real
MODE=paper
# true = solo longs, false = longs y shorts
LONG_ONLY=false
# Pares excluidos (separados por coma)
EXCLUDED_PAIRS=BTCUSDT,ETHUSDT

# ─── Dashboard ───────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_PASSWORD=apex2024

# ─── Logging ─────────────────────────────────────────
LOG_LEVEL=info
