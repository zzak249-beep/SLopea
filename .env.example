# ══════════════════════════════════════════════════════════════
#  QF×JP Bot v6.3 — Variables de Entorno
#  Copia a Railway → Variables (sin el prefijo #)
# ══════════════════════════════════════════════════════════════

# ── BingX API ──────────────────────────────────────────────────
BINGX_API_KEY=TU_API_KEY
BINGX_SECRET_KEY=TU_SECRET_KEY

# ── Telegram ───────────────────────────────────────────────────
TELEGRAM_TOKEN=123456789:ABC-tu_bot_token
TELEGRAM_CHAT_ID=-1001234567890

# ── Modo de operación ──────────────────────────────────────────
# SIGNAL = solo notifica, no abre trades reales
# LIVE   = abre y cierra trades reales en BingX
MODE=SIGNAL

# ── Capital y riesgo ───────────────────────────────────────────
CAPITAL=1000
RISK_PCT=1.0
LEVERAGE=10
MAX_OPEN_TRADES=5
MAX_DAILY_TRADES=20

# ── Umbrales de señal ──────────────────────────────────────────
MIN_SCORE=55
FUEL_SCORE=68
SUP_SCORE=80
MIN_TIER=FUEL           # STD | FUEL | SUP

# ── Lógica de entrada ──────────────────────────────────────────
REQUIRE_TL_BREAK=true
HTF_MIN_ALIGNED=2

# ── Scanner ────────────────────────────────────────────────────
SCAN_INTERVAL=180            # segundos entre ciclos (= 1 vela 3m)
TOP_N_SYMBOLS=0              # 0 = TODAS las monedas BingX con volumen suficiente
MIN_VOLUME_USDT=5000000      # filtro mínimo: 5M USDT volumen 24h
BLACKLIST=SOL-USDT,XRP-USDT  # excluir símbolos (separados por coma)

# ── Timeframes ─────────────────────────────────────────────────
TIMEFRAME=3m
HTF_TIMEFRAME=15m
HTF2_TIMEFRAME=1h
HTF5_TIMEFRAME=4h

# ── ATR / SL / TP ──────────────────────────────────────────────
ATR_LEN=10
SL_ATR_MULT=1.0
TP1_ATR_MULT=1.5
TP2_ATR_MULT=3.0

# ── ADX ────────────────────────────────────────────────────────
ADX_LEN=14
ADX_TREND=25
ADX_LATERAL=20

# ── Kelly ──────────────────────────────────────────────────────
KELLY_WIN_RATE=0.55
KELLY_RR=1.8
KELLY_FRACTION=0.25

# ── Circuit Breaker ────────────────────────────────────────────
CB_ENABLED=true
CB_ATR_MULT=3.0
CB_BARS=10

# ── Gestión de posiciones / cierre ─────────────────────────────
POSITION_CHECK_INTERVAL=30   # segundos entre chequeos de posiciones abiertas
BREAKEVEN_ATR_MULT=1.0       # mover SL a breakeven cuando precio avanza 1 ATR

# ── Port (Railway lo asigna automáticamente) ───────────────────
PORT=8080
