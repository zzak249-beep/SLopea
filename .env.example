# ─── BingX API ───────────────────────────────────────────────────────────────
BINGX_API_KEY=your_api_key_here
BINGX_SECRET_KEY=your_secret_key_here

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Strategy ─────────────────────────────────────────────────────────────────
EMA_FAST=7
EMA_SLOW=17
TIMEFRAME=5m
MIN_SLOPE_DEG=30
SLOPE_LOOKBACK=3

# ─── Risk ─────────────────────────────────────────────────────────────────────
LEVERAGE=10
RISK_PCT=1.0
ATR_SL_MULT=1.5
ATR_TP_MULT=2.5
ATR_PERIOD=14
MAX_OPEN_TRADES=5

# ─── Scanner ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL=60
MIN_VOLUME_USDT=5000000
MAX_WORKERS=10
MARGIN_TYPE=ISOLATED
