# ─── BingX API ─────────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_SECRET_KEY=tu_secret_key_aqui

# ─── Telegram ───────────────────────────────────────────
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ─── Pares a escanear (separados por coma) ──────────────
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT,BNB-USDT

# ─── Timeframes ─────────────────────────────────────────
TF_LOCAL=5m
TF_MACRO_1=15m
TF_MACRO_2=1h

# ─── SAMA Parameters ────────────────────────────────────
AMA_LENGTH=200
MAJOR_LENGTH=14
MINOR_LENGTH=6
SLOPE_PERIOD=34
SLOPE_RANGE=25
FLAT_THRESHOLD=17
ATR_PERIOD=14
ATR_MULT=2.0
RVOL_PERIOD=50
RVOL_MIN=1.2

# ─── Risk Management ────────────────────────────────────
LEVERAGE=5
RISK_PER_TRADE=0.01        # 1% del balance por trade
MAX_OPEN_TRADES=3
DAILY_LOSS_LIMIT=0.05      # -5% = circuit breaker
MIN_CONFLUENCE=60          # Score mínimo para entrar (0-100)
TRAILING_ENABLED=true
TRAILING_ATR_MULT=1.5

# ─── Filtros especiales (EDGE) ───────────────────────────
FUNDING_FILTER=true
FUNDING_EXTREME=0.0008     # 0.08% threshold para funding extremo
SESSION_FILTER=true        # Solo opera London/NY sessions

# ─── Bot ────────────────────────────────────────────────
SCAN_INTERVAL=60           # Segundos entre escaneos
PORT=8080                  # Puerto healthcheck Railway
